    .scope S_0x582569c5a150;
T_0 ;
    %vpi_call 2 18 "$display", "Starting V2X Collision Warning Test" {0 0 0};
    %pushi/vec4 50, 0, 8;
    %store/vec4 v0x582569c6ee90_0, 0, 8;
    %pushi/vec4 70, 0, 8;
    %store/vec4 v0x582569c6ef30_0, 0, 8;
    %delay 10000, 0;
    %vpi_call 2 25 "$display", "Distance Safe -> Warning = %b", v0x582569c6edf0_0 {0 0 0};
    %pushi/vec4 50, 0, 8;
    %store/vec4 v0x582569c6ee90_0, 0, 8;
    %pushi/vec4 55, 0, 8;
    %store/vec4 v0x582569c6ef30_0, 0, 8;
    %delay 10000, 0;
    %vpi_call 2 32 "$display", "Collision Risk -> Warning = %b", v0x582569c6edf0_0 {0 0 0};
    %delay 10000, 0;
    %vpi_call 2 36 "$finish" {0 0 0};
    %end;
    .thread T_0;
